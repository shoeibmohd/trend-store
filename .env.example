# Database (Neon PostgreSQL - https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT Secret (change this to a secure random string in production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Email Configuration (Nodemailer)
# For development, use Ethereal: https://ethereal.email/
# For production, use your SMTP provider (Gmail, SendGrid, etc.)
EMAIL_HOST="smtp.ethereal.email"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-ethereal-email@ethereal.email"
EMAIL_PASS="your-ethereal-password"
EMAIL_FROM="TrendHub UAE <noreply@trendhub.ae>"
ADMIN_EMAIL="admin@trendhub.ae"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Store WhatsApp Number (for quick inquiry button)
NEXT_PUBLIC_WHATSAPP_NUMBER="971501234567"
